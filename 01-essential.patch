+// Diagnostic helpers: parse comma-separated env vars into a set of op types.
+// ROCM_DENY_OPS="LayerNorm,GroupNorm" -> those ops will be pushed to CPU.
+// ROCM_ALLOW_OPS_ONLY="Conv,ConvTranspose" -> only those ops stay on ROCm, all
+//   other ops fall back to CPU. Takes precedence over deny.
+// ROCM_LOG_OP_PLACEMENT=1 -> stderr log of each node's placement decision.
+static std::unordered_set<std::string> ParseOpSetEnv(const char* var) {
+  std::unordered_set<std::string> s;
+  const char* v = std::getenv(var);
+  if (!v || !*v) return s;
+  std::string buf;
+  for (const char* p = v; ; ++p) {
+    if (*p == ',' || *p == '\0') {
+      if (!buf.empty()) s.insert(buf);
+      buf.clear();
+      if (*p == '\0') break;
+    } else if (*p != ' ' && *p != '\t') {
+      buf.push_back(*p);
+    }
+  }
+  return s;
+}
